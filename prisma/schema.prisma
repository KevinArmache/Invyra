// --- Configuration de la base de données ---
datasource db {
  provider = "postgresql"
}

// --- Générateur Prisma Client ---
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// --- Modèle Utilisateur ---
model User {
  id String @id @default(cuid())
  // ID unique de l'utilisateur, auto-généré par MongoDB

  email String @unique
  // Email unique pour l'identification / login

  name      String?
  company   String? // Société de l'utilisateur (optionnel)
  phone     String? // Téléphone (optionnel)
  password  String // Mot de passe hashé
  role      String   @default("user") // Rôle : "user" ou "admin"
  suspended Boolean  @default(false) // Indique si le compte est suspendu
  createdAt DateTime @default(now()) // Date de création du compte

  // 🔥 Abonnement
  plan String @default("free") // "free" | "premium" | "enterprise"	
  //  premiumUntil DateTime? // date d’expiration

  // Relations
  events         Event[] // Événements créés par cet utilisateur
  templates      Template[] // Templates créés par cet utilisateur
  collaborations Event_Collaborator[] // Événements où l'utilisateur est collaborateur

  @@map("users") // Nom réel de la collection dans MongoDB
}

// --- Modèle Template ---
model Template {
  id               String  @id @default(cuid())
  userId           String?
  eventId          String? @unique
  sourceTemplateId String?
  // Référence vers le propriétaire du template, nullable pour ne pas supprimer le template si l'utilisateur est supprimé

  name      String // Nom du template
  config    Json // Configuration / design du template en JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User?      @relation(fields: [userId], references: [id])
  event          Event?     @relation("EventTemplateCopy", fields: [eventId], references: [id], onDelete: Cascade)
  sourceTemplate Template?  @relation("TemplateCopies", fields: [sourceTemplateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  eventCopies    Template[] @relation("TemplateCopies")
  // Relation vers l'utilisateur, pas de cascade => le template reste si l'utilisateur est supprimé

  @@map("templates") // Nom réel de la collection dans MongoDB
}

// --- Modèle Event (Événement) ---
model Event {
  id     String @id @default(cuid())
  userId String
  // Propriétaire / créateur de l'événement

  title              String // Titre de l'événement
  description        String? // Description optionnelle
  eventDate          DateTime? // Date de l'événement
  location           String? // Lieu
  time               String? // Heure
  dressCode          String? // Code vestimentaire
  customMessage      String? // Message personnalisé pour les invités
  animationConfig    Json? // Configuration d'animations (JSON)
  invitationTemplate Json? // Template d'invitation spécifique
  emailTemplate      String? // Template d'email
  status             String    @default("draft") // État : draft | sent | etc.
  autoSend           Boolean   @default(false) // Envoi automatique activé ?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  user          User                 @relation(fields: [userId], references: [id])
  guests        Guest[] // Liste des invités
  collaborators Event_Collaborator[] // Collaborateurs de l'événement
  templateCopy  Template?            @relation("EventTemplateCopy")

  @@map("events")
}

// --- Modèle Event_Collaborator (Collaborateurs) ---
model Event_Collaborator {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  role        String   @default("editor") // "editor" ou "viewer"
  inviteToken String?  @unique // Token d'invitation unique
  accepted    Boolean  @default(false) // Si l'invitation a été acceptée
  createdAt   DateTime @default(now())

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // Si l'événement est supprimé, le collaborateur est supprimé

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Si l'utilisateur est supprimé, ce lien est supprimé
  // Un utilisateur ne peut être collaborateur qu'une seule fois par événement

  @@unique([eventId, userId])
  @@map("event_collaborators")
}

// --- Modèle Guest (Invité) ---
model Guest {
  id                  String  @id @default(cuid())
  eventId             String
  name                String
  email               String
  phone               String?
  dietaryRestrictions String? // Allergies / régime alimentaire
  plusOne             Boolean @default(false) // Si l'invité amène un accompagnant
  notes               String? // Notes supplémentaires

  invitationToken String  @unique // Token unique pour RSVP
  rsvpStatus      String? // Statut RSVP : accepted | declined | pending

  invitationSentAt   DateTime? // Dates de suivi des invitations
  emailSentAt        DateTime?
  whatsappSentAt     DateTime?
  invitationViewedAt DateTime?
  rsvpRespondedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // Si l'événement est supprimé, les invités liés sont supprimés
  // Un invité ne peut pas avoir deux fois le même email pour un événement donné

  @@unique([eventId, email])
  @@map("guests")
}
